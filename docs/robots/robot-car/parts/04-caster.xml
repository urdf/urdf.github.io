  <!-- ─────────────────────────────────────────────────────────────── -->
  <!-- CASTER WHEEL ASSEMBLY (front-center, -X side)                   -->
  <!-- Swivel caster: square mount plate + U-fork + rubber wheel       -->
  <!-- Joint hierarchy: base_link → caster_plate (fixed)              -->
  <!--                  caster_plate → caster_fork (continuous, Z)    -->
  <!--                  caster_fork → caster_wheel (continuous, roll) -->
  <!-- Floor plane: drive wheels center at Z=-0.0110,                 -->
  <!--   radius=0.0325 → floor at Z=-0.0435.                          -->
  <!-- Caster wheel radius=0.0146 → center at Z=-0.0289 in world      -->
  <!--   fork origin at Z=-0.006 → wheel offset -0.0229 from fork     -->
  <!-- ─────────────────────────────────────────────────────────────── -->

  <!-- Mount plate: ~36×36×4 mm aluminium -->
  <link name="caster_plate">
    <visual>
      <geometry>
        <box size="0.036 0.036 0.004"/>
      </geometry>
      <material name="caster_metal">
        <color rgba="0.76 0.76 0.78 1.00"/>
      </material>
    </visual>
    <!-- aluminium plate ~15 g; 36×36×4 mm box -->
    <inertial>
      <mass value="0.015"/>
      <inertia ixx="1.64e-6" ixy="0" ixz="0" iyy="1.64e-6" iyz="0" izz="3.24e-6"/>
    </inertial>
  </link>
  <joint name="caster_plate_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_plate"/>
    <origin xyz="-0.1200 0.0000 -0.0040" rpy="0 0 0"/>
  </joint>

  <!-- Swivel fork: U-bracket (two side arms + top crossbar)          -->
  <!-- Origin at swivel pin = bottom face of plate (Z=-0.006 world)   -->
  <link name="caster_fork">
    <!-- Left arm (-Y side) -->
    <visual>
      <origin xyz="0 -0.0093 -0.0115" rpy="0 0 0"/>
      <geometry><box size="0.006 0.002 0.023"/></geometry>
      <material name="caster_metal">
        <color rgba="0.76 0.76 0.78 1.00"/>
      </material>
    </visual>
    <!-- Right arm (+Y side) -->
    <visual>
      <origin xyz="0 0.0093 -0.0115" rpy="0 0 0"/>
      <geometry><box size="0.006 0.002 0.023"/></geometry>
      <material name="caster_metal">
        <color rgba="0.76 0.76 0.78 1.00"/>
      </material>
    </visual>
    <!-- Top crossbar -->
    <visual>
      <origin xyz="0 0 -0.001" rpy="0 0 0"/>
      <geometry><box size="0.006 0.020 0.002"/></geometry>
      <material name="caster_metal">
        <color rgba="0.76 0.76 0.78 1.00"/>
      </material>
    </visual>
    <!-- plastic fork ~8 g -->
    <inertial>
      <mass value="0.008"/>
      <inertia ixx="7.71e-7" ixy="0" ixz="0" iyy="6.43e-7" iyz="0" izz="2.13e-7"/>
    </inertial>
  </link>
  <!-- Swivel joint: fork rotates around vertical Z at plate bottom -->
  <joint name="caster_fork_joint" type="continuous">
    <parent link="caster_plate"/>
    <child link="caster_fork"/>
    <origin xyz="0 0 -0.002" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Swivel wheel: radius=14.6 mm, length=14.5 mm                   -->
  <!-- In fork frame: center at Z=-0.0229                              -->
  <!-- In world frame: -0.006 (fork) + -0.0229 = -0.0289             -->
  <!-- Bottom touches floor at -0.0435, same as drive wheels           -->
  <link name="caster_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.0146" length="0.0145"/>
      </geometry>
      <material name="caster_rubber">
        <color rgba="0.08 0.08 0.08 1.00"/>
      </material>
    </visual>
    <!-- small caster ~10 g -->
    <inertial>
      <mass value="0.010"/>
      <inertia ixx="7.1e-7" ixy="0" ixz="0" iyy="7.1e-7" iyz="0" izz="1.06e-6"/>
    </inertial>
    <collision>
      <geometry>
        <cylinder radius="0.0146" length="0.0145"/>
      </geometry>
    </collision>
  </link>
  <joint name="caster_wheel_joint" type="continuous">
    <parent link="caster_fork"/>
    <child link="caster_wheel"/>
    <origin xyz="0 0 -0.0229" rpy="1.5708 0.0000 0.0000"/>
    <axis xyz="0 0 1"/>
    <limit effort="1.0" velocity="15.0"/>
  </joint>
