  <!-- ─────────────────────────────────────────────────────────────── -->
  <!-- CHASSIS                                                          -->
  <!-- Clear acrylic base plate: 220 × 150 × 3 mm                     -->
  <!-- Mesh: rounded body + curved front bumper arc (generated STL)   -->
  <!-- Bumper at -X (front/camera-facing), rear at +X                 -->
  <!-- ─────────────────────────────────────────────────────────────── -->
  <!-- base_link is the root reference frame (no visual) -->
  <link name="base_link"/>

  <!-- chassis is a child of base_link so the Inspector can select/scale it -->
  <joint name="chassis_joint" type="fixed">
    <parent link="base_link"/>
    <child link="chassis"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="chassis">
    <visual>
      <geometry>
        <mesh filename="chassis.stl"/>
      </geometry>
      <material name="acrylic">
        <color rgba="0.85 0.95 1.00 0.25"/>
      </material>
    </visual>
    <!-- 220×150×3 mm acrylic plate ~0.15 kg; COM at chassis_joint origin -->
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.000281" ixy="0" ixz="0" iyy="0.000605" iyz="0" izz="0.000886"/>
    </inertial>
    <collision>
      <geometry>
        <box size="0.220 0.150 0.003"/>
      </geometry>
    </collision>
  </link>
