<?xml version="1.0"?>
<!--
  Physical Agents OS — 2WD Robot Car
  Dimensions sourced from manufacturer datasheets and verified product listings.

  Coordinate convention (viewer-oriented, Z-up):
    -X = forward (bumper / front)   X = rear
    -Y = left                       Y = right
     Z = up

  Note: with -X as forward, RHR gives left = Z × (-X) = -Y.

  Note: bumper is at -X so it faces the viewer's default camera
  (Three.js camera dir (-1, 0.7, 1) → URDF -X side is camera-facing).

  Component sources:
    Chassis    — 220×150×3 mm acrylic (2WD kit, confirmed multiple sellers)
    TT Motor   — 70×22×18 mm body, 10 mm shaft @ ø5.3 mm (Adafruit #3777)
    Wheels     — ø65 mm × 25 mm rubber (Adafruit #3763)
    Caster     — 20 mm total height, 15.7 mm ball (Adafruit #3948)
    L298N      — 43×43×27.5 mm PCB + heatsink (Components101 datasheet)
    ESP32-CAM  — 40×27×12 mm incl. camera assembly (DFRobot DFR0602)
    HC-SR04    — 45×20×15 mm (SparkFun datasheet)
    Power bank — ø35×92 mm cylinder (SIXTHGU, estimated)
    9V battery — 62×27×22 mm holder (estimated)

  All dimensions in meters.
-->
<robot name="robot-car">

  <!-- ─────────────────────────────────────────────────────────────── -->
  <!-- CHASSIS                                                          -->
  <!-- Clear acrylic base plate: 220 × 150 × 3 mm                     -->
  <!-- Mesh: rounded body + curved front bumper arc (generated STL)   -->
  <!-- Bumper at -X (front/camera-facing), rear at +X                 -->
  <!-- ─────────────────────────────────────────────────────────────── -->
  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="chassis.stl"/>
      </geometry>
      <material name="acrylic">
        <color rgba="0.72 0.91 1.00 0.50"/>
      </material>
    </visual>
  </link>

  <!-- ─────────────────────────────────────────────────────────────── -->
  <!-- LEFT DRIVE MOTOR                                                 -->
  <!-- TT gearbox body: 70 × 22 × 18 mm, shaft along +Y               -->
  <!-- ─────────────────────────────────────────────────────────────── -->
  <link name="motor_left">
    <visual>
      <geometry>
        <box size="0.022 0.070 0.018"/>
      </geometry>
      <material name="motor">
        <color rgba="0.25 0.25 0.28 1.00"/>
      </material>
    </visual>
  </link>
  <joint name="motor_left_joint" type="fixed">
    <parent link="base_link"/>
    <child link="motor_left"/>
    <origin xyz="-0.010 -0.040 -0.009" rpy="0 0 0"/>
  </joint>

  <!-- ─────────────────────────────────────────────────────────────── -->
  <!-- RIGHT DRIVE MOTOR                                                -->
  <!-- ─────────────────────────────────────────────────────────────── -->
  <link name="motor_right">
    <visual>
      <geometry>
        <box size="0.022 0.070 0.018"/>
      </geometry>
      <material name="motor">
        <color rgba="0.25 0.25 0.28 1.00"/>
      </material>
    </visual>
  </link>
  <joint name="motor_right_joint" type="fixed">
    <parent link="base_link"/>
    <child link="motor_right"/>
    <origin xyz="-0.010 0.040 -0.009" rpy="0 0 0"/>
  </joint>

  <!-- ─────────────────────────────────────────────────────────────── -->
  <!-- LEFT WHEEL                                                       -->
  <!-- Rubber tire: ø65 mm × 25 mm. Joint at motor shaft center.       -->
  <!-- ─────────────────────────────────────────────────────────────── -->
  <link name="wheel_left">
    <visual>
      <geometry>
        <cylinder radius="0.0325" length="0.025"/>
      </geometry>
      <material name="rubber">
        <color rgba="0.10 0.10 0.10 1.00"/>
      </material>
    </visual>
  </link>
  <joint name="wheel_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_left"/>
    <!-- rpy rotates cylinder from Z-axis to Y-axis so wheel spins around Y -->
    <origin xyz="-0.010 -0.090 -0.002" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="2.0" velocity="15.0"/>
  </joint>

  <!-- ─────────────────────────────────────────────────────────────── -->
  <!-- RIGHT WHEEL                                                      -->
  <!-- ─────────────────────────────────────────────────────────────── -->
  <link name="wheel_right">
    <visual>
      <geometry>
        <cylinder radius="0.0325" length="0.025"/>
      </geometry>
      <material name="rubber">
        <color rgba="0.10 0.10 0.10 1.00"/>
      </material>
    </visual>
  </link>
  <joint name="wheel_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_right"/>
    <origin xyz="-0.010 0.090 -0.002" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="2.0" velocity="15.0"/>
  </joint>

  <!-- ─────────────────────────────────────────────────────────────── -->
  <!-- CASTER WHEEL ASSEMBLY (front-center, -X side)                   -->
  <!-- Swivel caster: square mount plate + steel fork + rubber wheel   -->
  <!-- Three parts share X/Y; stacked down from chassis underside      -->
  <!-- ─────────────────────────────────────────────────────────────── -->

  <!-- Mount plate: ~36×36×4 mm clear/steel -->
  <link name="caster_plate">
    <visual>
      <geometry>
        <box size="0.036 0.036 0.004"/>
      </geometry>
      <material name="caster_metal">
        <color rgba="0.76 0.76 0.78 1.00"/>
      </material>
    </visual>
  </link>
  <joint name="caster_plate_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_plate"/>
    <origin xyz="-0.065 0.000 -0.004" rpy="0 0 0"/>
  </joint>

  <!-- Swivel fork: thin U-bracket ~8×30×26 mm steel -->
  <link name="caster_fork">
    <visual>
      <geometry>
        <box size="0.008 0.030 0.026"/>
      </geometry>
      <material name="caster_metal">
        <color rgba="0.76 0.76 0.78 1.00"/>
      </material>
    </visual>
  </link>
  <joint name="caster_fork_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_fork"/>
    <origin xyz="-0.065 0.000 -0.019" rpy="0 0 0"/>
  </joint>

  <!-- Caster wheel: ø38 mm × 16 mm black rubber -->
  <link name="caster_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.019" length="0.016"/>
      </geometry>
      <material name="caster_rubber">
        <color rgba="0.08 0.08 0.08 1.00"/>
      </material>
    </visual>
  </link>
  <joint name="caster_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <!-- wheel axis along Y; center at base of fork -->
    <origin xyz="-0.065 0.000 -0.037" rpy="1.5708 0 0"/>
  </joint>

  <!-- ─────────────────────────────────────────────────────────────── -->
  <!-- L298N DUAL H-BRIDGE MOTOR DRIVER                                 -->
  <!-- PCB + heatsink: 43 × 43 × 27.5 mm (Components101 datasheet)    -->
  <!-- ─────────────────────────────────────────────────────────────── -->
  <link name="l298n">
    <visual>
      <geometry>
        <box size="0.043 0.043 0.0275"/>
      </geometry>
      <material name="pcb_blue">
        <color rgba="0.06 0.20 0.78 1.00"/>
      </material>
    </visual>
  </link>
  <joint name="l298n_joint" type="fixed">
    <parent link="base_link"/>
    <child link="l298n"/>
    <origin xyz="0.020 0.042 0.0153" rpy="0 0 0"/>
  </joint>

  <!-- ─────────────────────────────────────────────────────────────── -->
  <!-- ESP32-CAM-MB                                                     -->
  <!-- Board + camera assembly: 40 × 27 × 12 mm (DFRobot DFR0602)     -->
  <!-- Mounted near front (-X), lens facing forward                    -->
  <!-- ─────────────────────────────────────────────────────────────── -->
  <link name="esp32cam">
    <visual>
      <geometry>
        <box size="0.040 0.027 0.012"/>
      </geometry>
      <material name="pcb_green">
        <color rgba="0.08 0.32 0.10 1.00"/>
      </material>
    </visual>
  </link>
  <joint name="esp32cam_joint" type="fixed">
    <parent link="base_link"/>
    <child link="esp32cam"/>
    <origin xyz="-0.080 0.000 0.0090" rpy="0 0 0"/>
  </joint>

  <!-- ─────────────────────────────────────────────────────────────── -->
  <!-- HC-SR04 ULTRASONIC SENSOR                                        -->
  <!-- PCB: 45 × 20 × 15 mm (SparkFun datasheet, confirmed Adafruit)  -->
  <!-- Mounted at bumper tip (-X), facing forward                      -->
  <!-- ─────────────────────────────────────────────────────────────── -->
  <link name="hcsr04">
    <visual>
      <geometry>
        <box size="0.045 0.020 0.015"/>
      </geometry>
      <material name="pcb_teal">
        <color rgba="0.05 0.48 0.58 1.00"/>
      </material>
    </visual>
  </link>
  <joint name="hcsr04_joint" type="fixed">
    <parent link="base_link"/>
    <child link="hcsr04"/>
    <origin xyz="-0.110 0.000 0.0090" rpy="0 0 0"/>
  </joint>

  <!-- ─────────────────────────────────────────────────────────────── -->
  <!-- POWER BANK (SIXTHGU)                                             -->
  <!-- Cylindrical: ø35 mm × 92 mm length (estimated; not datasheet)  -->
  <!-- Lying along X axis on top, rear area                            -->
  <!-- ─────────────────────────────────────────────────────────────── -->
  <link name="powerbank">
    <visual>
      <geometry>
        <cylinder radius="0.0175" length="0.092"/>
      </geometry>
      <material name="silver">
        <color rgba="0.62 0.63 0.65 1.00"/>
      </material>
    </visual>
  </link>
  <joint name="powerbank_joint" type="fixed">
    <parent link="base_link"/>
    <child link="powerbank"/>
    <!-- rpy rotates cylinder from Z-axis to X-axis so it lies horizontally -->
    <origin xyz="0.025 -0.030 0.0220" rpy="0 1.5708 0"/>
  </joint>

  <!-- ─────────────────────────────────────────────────────────────── -->
  <!-- 9V BATTERY PACK                                                  -->
  <!-- Holder: ~62 × 27 × 22 mm (estimated; mounted underside, rear)  -->
  <!-- ─────────────────────────────────────────────────────────────── -->
  <link name="battery_9v">
    <visual>
      <geometry>
        <box size="0.062 0.027 0.022"/>
      </geometry>
      <material name="battery">
        <color rgba="0.12 0.12 0.14 1.00"/>
      </material>
    </visual>
  </link>
  <joint name="battery_9v_joint" type="fixed">
    <parent link="base_link"/>
    <child link="battery_9v"/>
    <origin xyz="0.050 -0.038 -0.0135" rpy="0 0 0"/>
  </joint>

  <!--
    NOT YET INSTALLED (from physical-agents component catalog):
      - MH IR sensor (32×14 mm) — front underside, angled down for line following
      - Logic level converter (19×14 mm) — between HC-SR04 and ESP32
      - Encoder discs L/R (~30 mm ø × 3 mm) — on wheel inner hubs
    Add these as fixed links once physically installed.
  -->

</robot>
